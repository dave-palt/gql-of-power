{
	"name": "@dav3/gql-of-power",
	"version": "1.0.1",
	"description": "Generate a single optimized SQL query from GraphQL operations — eliminate N+1 with recursive field-to-SQL mapping.",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"module": "esnext",
	"repository": {
		"url": "https://github.com/dave-palt/gql-of-power",
		"directory": "gql-of-power",
		"type": "git"
	},
	"scripts": {
		"build": "tsc",
		"watch": "tsc --watch",
		"prepublishOnly": "bun run build",
		"test": "D3GOP_LOG_TYPE=\"disabled\" bun test",
		"test:unit": "D3GOP_LOG_TYPE=\"disabled\" bun test --filter='unit'",
		"test:integration": "D3GOP_LOG_TYPE=\"disabled\" bun test --filter='integration'",
		"test:watch": "D3GOP_LOG_TYPE=\"disabled\" bun test --watch",
		"test:coverage": "D3GOP_LOG_TYPE=\"disabled\" bun test --coverage",
		"format": "bunx prettier --write .",
		"format:check": "bunx prettier --check .",
		"typecheck": "tsc --noEmit",
		"precommit": "bun run format && bun run typecheck && bun run test"
	},
	"keywords": [],
	"author": "",
	"license": "MIT NON-AI License",
	"devDependencies": {
		"@graphql-tools/schema": "^10.0.25",
		"@types/bun": "latest",
		"@types/graphql-fields": "^1.3.9",
		"@types/node": "^22.15.17",
		"concurrently": "^9.1.2",
		"graphql-yoga": "^5.16.0",
		"pg": "^8.16.3",
		"reflect-metadata": "^0.2.2",
		"typescript": "^5.8.3"
	},
	"dependencies": {
		"graphql": "^16.13.2",
		"graphql-fields": "^2.0.3",
		"graphql-parse-resolve-info": "^4.14.1",
		"knex": "^3.1.0",
		"type-graphql": "^2.0.0-rc.2"
	},
	"workspaces": [
		"examples/*"
	]
}
